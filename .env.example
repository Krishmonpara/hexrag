# Copy to .env and adjust. All values are optional — hexrag runs with none of them.

# Which settings profile(s) to load (comma-separated). Default = mock.
# HEXRAG_PROFILES=ollama

# Server bind
# HEXRAG_HOST=0.0.0.0
# HEXRAG_PORT=8001

# Where ingested data is persisted
# HEXRAG_DATA_FOLDER=./local_data

# --- Ollama profile ---
# OLLAMA_API_BASE=http://localhost:11434
# OLLAMA_LLM_MODEL=llama3.2
# OLLAMA_EMBED_MODEL=nomic-embed-text

# --- OpenAI profile ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small
